{
    "name": "GQE Development Environment(aarch64)",
    "build": {
        "dockerfile": "${localWorkspaceFolder}/.devcontainer/Dockerfile",
        "args": {
            "IMAGE": "gitlab-master.nvidia.com/devtech-compute/gqe:latest_aarch64",
            "DEV_UID": "${localEnv:UID}",
            "DEV_GID": "${localEnv:GID}"
        }
    },
    "containerEnv": {
        "NVIDIA_VISIBLE_DEVICES": "all",
        "NVIDIA_DRIVER_CAPABILITIES": "compute,utility"
    },
    "remoteUser": "gqe-dev",
    "updateRemoteUserUID": false,
    "workspaceFolder": "/workspace",
    "postCreateCommand": "bash .devcontainer/setup-devcontainer.sh",
    "runArgs": [
        "--name=gqe-dev",
        "--gpus=all",
        "--security-opt=seccomp=unconfined",
        "--cap-add=SYS_PTRACE"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cmake-tools",
                "rust-lang.rust-analyzer",
                "ms-vscode.cpptools",
                "anysphere.cpptools",
                "ms-python.python",
                "nvidia.nsight-vscode-edition"
            ],
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash",
                "terminal.integrated.profiles.linux": {
                    "bash": {
                        "path": "/bin/bash"
                    }
                }
            }
        }
    },
    "mounts": [
        "source=${localWorkspaceFolder}/.devcontainer,target=/workspace/.devcontainer,type=bind,consistency=cached",
        "source=/tmp,target=/tmp,type=bind,consistency=cached",
        "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached"
    ]
}
